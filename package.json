{
  "name": "portfolio-vue-ts-composition",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s update-fixture type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "build-only": "vite-ssg build",
    "type-check": "vue-tsc --build",
    "update-fixture": "node updateLocaleModelsFixture.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js,vue,css}": "prettier --write",
    "tests/**/*.ts": "prettier --write",
    "src/**/*.{ts,js,vue}": [
      "eslint",
      "vitest run --coverage"
    ]
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.2",
    "@vueuse/core": "^14.1.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@headlessui/vue": "^1.7.23",
    "@tailwindcss/vite": "^4.1.13",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "animate.css": "^4.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "swiper": "^12.1.3",
    "tailwindcss": "^4.1.13",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.1.2",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-ssg": "^28.3.0",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.0.5"
  }
}
